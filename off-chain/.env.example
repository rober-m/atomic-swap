# Off-chain secrets for submitting transactions.
# Copy this file to `.env.local` (gitignored) and fill in the values.
# CARDANO_NETWORK and the connection details (INDEXER_URL) are read from the
# shared ../.env.

# Where transactions go is decided by ../.env, not here:
#   • INDEXER_URL set (a local devnet, e.g. Yaci DevKit's `just dev`) → that
#     devnet is used and BLOCKFROST_PROJECT_ID is NOT needed.
#   • INDEXER_URL absent → Blockfrost is used and BLOCKFROST_PROJECT_ID below
#     is required.

# Blockfrost project id for your target network — https://blockfrost.io
# Only needed when NOT using a local devnet.
BLOCKFROST_PROJECT_ID=

# Mnemonic (space-separated words) of the wallet that funds and signs txs.
# Required in both modes. Use a throwaway test wallet — never commit a real seed
# phrase. On a local devnet any throwaway wallet works; `create` tops it up from
# the faucet automatically.
MNEMONIC=
